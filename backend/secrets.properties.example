# ============================================================
# API Key 配置模板
# 使用方法：复制本文件为 secrets.properties，填入真实 Key
#   cp secrets.properties.example secrets.properties
# ============================================================

# MiniMax M3 API Key（从 https://platform.minimaxi.com 获取）
mini-max.api-key=YOUR_MINIMAX_API_KEY

# DeepSeek API Key（可选，使用 DeepSeek 模型时需要）
deepseek.api-key=YOUR_DEEPSEEK_API_KEY
